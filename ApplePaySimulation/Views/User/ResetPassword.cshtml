@model ApplePaySimulation.Models.ViewModels.Authentication.ResetPasswordViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>XenoPay · Reset Password</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-base: #05070A;
            --bg-surface: #10141D;
            --text-main: #F1F5F9;
            --text-muted: #8B9BB4;
            --text-faint: #4A5568;
            --accent-blue: #2E7BCF;
            --border-color: #2A3647;
            --border-dim: #1A2535;
            --danger: #FF6B6B;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', system-ui, sans-serif;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .mobile-device {
            width: 100%;
            max-width: 390px;
            height: 100vh;
            max-height: 844px;
            background: var(--bg-base);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            border: 1px solid #1A212D;
        }

        @@media (min-width: 400px) {
            .mobile-device {
                height: 844px;
                border-radius: 40px;
                box-shadow: 0 0 50px rgba(0,0,0,0.8), inset 0 0 0 6px #000;
            }
        }

        .bg-glow {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
            z-index: 0;
        }

        .glow-blue {
            width: 260px;
            height: 260px;
            background: rgba(46,123,207,0.12);
            top: -60px;
            left: -60px;
        }

        .status-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 24px 0;
            z-index: 10;
            position: relative;
        }

        .status-time {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-main);
        }

        .auth-content {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            padding: 0 28px 40px;
            position: relative;
            z-index: 1;
        }

        .auth-heading {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: -0.4px;
            margin-bottom: 6px;
        }

        .auth-sub {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 32px;
            line-height: 1.5;
        }

        .field {
            margin-bottom: 14px;
        }

            .field label {
                display: block;
                font-size: 11px;
                font-weight: 600;
                color: var(--text-muted);
                letter-spacing: 0.08em;
                text-transform: uppercase;
                margin-bottom: 7px;
            }

        .field-wrap input {
            width: 100%;
            background: var(--bg-surface);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 15px 16px;
            border-radius: 14px;
            font-size: 15px;
            font-family: 'DM Sans', system-ui, sans-serif;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .field-wrap input::placeholder {
                color: var(--text-faint);
            }

            .field-wrap input:focus {
                border-color: var(--accent-blue);
                box-shadow: 0 0 0 3px rgba(46,123,207,0.12);
            }

            .field-wrap input.input-validation-error {
                border-color: var(--danger);
            }

        .field-validation-error {
            font-size: 12px;
            color: var(--danger);
            margin-top: 5px;
            display: block;
        }

        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
        }

        .validation-summary-errors li {
            font-size: 13px;
            color: var(--danger);
            margin-bottom: 4px;
        }

        .btn-auth {
            width: 100%;
            padding: 16px;
            border-radius: 14px;
            border: none;
            background: var(--accent-blue);
            color: #fff;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            font-family: 'DM Sans', system-ui, sans-serif;
            transition: opacity 0.2s;
            margin-top: 6px;
        }

            .btn-auth:hover {
                opacity: 0.88;
            }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 500;
            font-family: 'DM Sans', system-ui, sans-serif;
            padding: 0;
            transition: color 0.15s;
            margin-bottom: 24px;
            text-decoration: none;
        }

            .back-btn svg {
                width: 18px;
                height: 18px;
                stroke: currentColor;
                fill: none;
                stroke-width: 2.2;
            }
    </style>
</head>
<body>
    <div class="mobile-device">
        <div class="bg-glow glow-blue"></div>
        <div class="status-bar">
            <span class="status-time" id="clock">9:41</span>
        </div>
        <div class="auth-content">
            <a class="back-btn" href="@Url.Action("Login", "User")">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                Back
            </a>
            <div style="padding: 0 0 28px;">
                <div class="auth-heading">Reset Password</div>
                <div class="auth-sub">Enter your email and we'll send you a reset link.</div>
            </div>

            @using (Html.BeginForm("ConfirmResetPassword", "User", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="field">
                    <label asp-for="Email">Email Address</label>
                    <div class="field-wrap">
                        <input asp-for="Email" type="email" placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn-auth">Send Reset Link</button>
            }
        </div>
    </div>
    <script>
        function updateClock() {
            document.getElementById('clock').textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }
        updateClock(); setInterval(updateClock, 10000);
    </script>
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
