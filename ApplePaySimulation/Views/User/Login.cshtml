@model ApplePaySimulation.Models.ViewModels.Authentication.LoginViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>XenoPay · Sign In</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-base: #05070A;
            --bg-surface: #10141D;
            --bg-card: #1A212D;
            --text-main: #F1F5F9;
            --text-muted: #8B9BB4;
            --text-faint: #4A5568;
            --accent-blue: #2E7BCF;
            --accent-blue-dim: #1C3F6B;
            --accent-green: #46E5A6;
            --border-color: #2A3647;
            --border-dim: #1A2535;
            --danger: #FF6B6B;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', system-ui, sans-serif;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .mobile-device {
            width: 100%;
            max-width: 390px;
            height: 100vh;
            max-height: 844px;
            background: var(--bg-base);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            border: 1px solid #1A212D;
        }

        @@media (min-width: 400px) {
            .mobile-device {
                height: 844px;
                border-radius: 40px;
                box-shadow: 0 0 50px rgba(0,0,0,0.8), inset 0 0 0 6px #000;
            }
        }

        .bg-glow {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
            z-index: 0;
        }

        .glow-blue {
            width: 260px;
            height: 260px;
            background: rgba(46,123,207,0.12);
            top: -60px;
            left: -60px;
        }

        .status-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 24px 0;
            z-index: 10;
            position: relative;
        }

        .status-time {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-main);
        }

        .status-icons {
            display: flex;
            gap: 6px;
            align-items: center;
        }

            .status-icons svg {
                width: 16px;
                height: 16px;
                fill: var(--text-main);
            }

        .auth-content {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            padding: 0 28px 40px;
            position: relative;
            z-index: 1;
        }

        .auth-heading {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: -0.4px;
            margin-bottom: 6px;
        }

        .auth-sub {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 32px;
            line-height: 1.5;
        }

        .field {
            margin-bottom: 14px;
        }

            .field label {
                display: block;
                font-size: 11px;
                font-weight: 600;
                color: var(--text-muted);
                letter-spacing: 0.08em;
                text-transform: uppercase;
                margin-bottom: 7px;
            }

        .field-wrap {
            position: relative;
        }

            .field-wrap input {
                width: 100%;
                background: var(--bg-surface);
                border: 1px solid var(--border-color);
                color: var(--text-main);
                padding: 15px 46px 15px 16px;
                border-radius: 14px;
                font-size: 15px;
                font-family: 'DM Sans', system-ui, sans-serif;
                outline: none;
                transition: border-color 0.2s, box-shadow 0.2s;
            }

                .field-wrap input::placeholder {
                    color: var(--text-faint);
                }

                .field-wrap input:focus {
                    border-color: var(--accent-blue);
                    box-shadow: 0 0 0 3px rgba(46,123,207,0.12);
                }

                .field-wrap input.input-validation-error {
                    border-color: var(--danger);
                }

        .field-icon {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-faint);
            cursor: pointer;
            display: flex;
            align-items: center;
            transition: color 0.15s;
        }

            .field-icon svg {
                width: 18px;
                height: 18px;
                stroke: currentColor;
                fill: none;
                stroke-width: 2;
            }

        .field-validation-error {
            font-size: 12px;
            color: var(--danger);
            margin-top: 5px;
            display: block;
        }

        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
        }

        .validation-summary-errors li {
            font-size: 13px;
            color: var(--danger);
            margin-bottom: 4px;
            text-align: center;
        }

        .forgot-row {
            text-align: right;
            margin-top: -6px;
            margin-bottom: 14px;
        }

            .forgot-row a {
                font-size: 13px;
                color: var(--accent-blue);
                text-decoration: none;
            }

        .btn-auth {
            width: 100%;
            padding: 16px;
            border-radius: 14px;
            border: none;
            background: var(--accent-blue);
            color: #fff;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            font-family: 'DM Sans', system-ui, sans-serif;
            transition: opacity 0.2s, transform 0.15s;
            position: relative;
            overflow: hidden;
            margin-top: 6px;
        }

            .btn-auth::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
            }

            .btn-auth:hover {
                opacity: 0.88;
            }

            .btn-auth:active {
                transform: scale(0.98);
            }

        .divider-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 22px 0;
        }

            .divider-row::before, .divider-row::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border-dim);
            }

            .divider-row span {
                font-size: 12px;
                color: var(--text-faint);
                white-space: nowrap;
            }

        .btn-biometric {
            width: 100%;
            padding: 14px 16px;
            border-radius: 14px;
            border: 1px solid var(--border-color);
            background: var(--bg-surface);
            color: var(--text-main);
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            font-family: 'DM Sans', system-ui, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: background 0.2s;
        }

            .btn-biometric svg {
                width: 20px;
                height: 20px;
            }

        .auth-footer {
            text-align: center;
            margin-top: 24px;
        }

            .auth-footer p {
                font-size: 14px;
                color: var(--text-muted);
            }

            .auth-footer a {
                color: var(--accent-blue);
                font-weight: 600;
                text-decoration: none;
            }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 500;
            font-family: 'DM Sans', system-ui, sans-serif;
            padding: 0;
            transition: color 0.15s;
            margin-bottom: 24px;
            text-decoration: none;
        }

            .back-btn svg {
                width: 18px;
                height: 18px;
                stroke: currentColor;
                fill: none;
                stroke-width: 2.2;
            }

            .back-btn:hover {
                color: var(--text-main);
            }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
        }

            .remember-row input[type="checkbox"] {
                width: 18px;
                height: 18px;
                accent-color: var(--accent-blue);
                cursor: pointer;
            }

            .remember-row label {
                font-size: 13px;
                color: var(--text-muted);
                cursor: pointer;
            }

        .auth-content::-webkit-scrollbar {
            width: 0;
        }
    </style>
</head>
<body>
    <div class="mobile-device">
        <div class="bg-glow glow-blue"></div>

        <div class="status-bar">
            <span class="status-time" id="clock">9:41</span>
            <div class="status-icons">
                <svg viewBox="0 0 24 24"><rect x="2" y="14" width="3" height="7" rx="1" /><rect x="7" y="10" width="3" height="11" rx="1" /><rect x="12" y="6" width="3" height="15" rx="1" /><rect x="17" y="2" width="3" height="19" rx="1" /></svg>
                <svg viewBox="0 0 24 24"><rect x="1" y="7" width="18" height="10" rx="2" stroke="white" stroke-width="1.5" fill="none" /><path d="M23 11v2" stroke="white" stroke-width="2" stroke-linecap="round" /><rect x="3" y="9" width="12" height="6" rx="1" fill="white" /></svg>
            </div>
        </div>

        <div class="auth-content">
            <a class="back-btn" href="@Url.Action("Index", "Home")">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                Back
            </a>

            <div style="padding: 0 0 28px;">
                <div class="auth-heading">Welcome back</div>
                <div class="auth-sub">Sign in to your XenoPay account</div>
            </div>

            @Html.AntiForgeryToken()

            @using (Html.BeginForm("SaveLogin", "User", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <input type="hidden" asp-for="ReturnUrl" />

                <div class="field">
                    <label asp-for="Email">Email</label>
                    <div class="field-wrap">
                        <input asp-for="Email" type="email" placeholder="you@example.com" autocomplete="email" />
                        <div class="field-icon">
                            <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                        </div>
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="field">
                    <label asp-for="Password">Password</label>
                    <div class="field-wrap">
                        <input asp-for="Password" type="password" id="si-password" placeholder="Enter your password" autocomplete="current-password" />
                        <div class="field-icon" onclick="togglePwd('si-password', this)" style="cursor:pointer;">
                            <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                        </div>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="remember-row">
                    <input asp-for="RememberMe" type="checkbox" id="RememberMe" />
                    <label for="RememberMe">Remember me</label>
                </div>

                <div class="forgot-row">
                    <a href="@Url.Action("ResetPassword", "User")">Forgot password?</a>
                </div>

                <button type="submit" class="btn-auth">Sign In</button>
            }

            <div class="divider-row"><span>or continue with</span></div>

            <button class="btn-biometric" onclick="alert('Face ID not available in browser mode.')">
                <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 8V6a2 2 0 0 1 2-2h2M16 4h2a2 2 0 0 1 2 2v2M22 16v2a2 2 0 0 1-2 2h-2M8 20H6a2 2 0 0 1-2-2v-2" />
                    <path d="M9 10h.01M15 10h.01M9.5 15a3.5 3.5 0 0 0 5 0" />
                </svg>
                Sign in with Face ID
            </button>

            <div class="auth-footer">
                <p>Don't have an account? <a href="@Url.Action("Register", "User")">Create one</a></p>
            </div>
        </div>
    </div>

    <script>
        function updateClock() {
            const t = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            document.getElementById('clock').textContent = t;
        }
        updateClock();
        setInterval(updateClock, 10000);

        function togglePwd(inputId, iconEl) {
            const inp = document.getElementById(inputId);
            const showing = inp.type === 'text';
            inp.type = showing ? 'password' : 'text';
            iconEl.innerHTML = showing
                ? `<svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`
                : `<svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;
        }
    </script>
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
