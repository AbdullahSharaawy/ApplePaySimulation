@{
    Layout = null;
    string email = ViewBag.Email ?? "your inbox";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>XenoPay · Check Your Email</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg-base:#05070A; --bg-surface:#10141D; --text-main:#F1F5F9; --text-muted:#8B9BB4; --accent-blue:#2E7BCF; --accent-green:#46E5A6; --border-color:#2A3647; }
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:'DM Sans',sans-serif; background:#000; display:flex; align-items:center; justify-content:center; min-height:100vh; }
        .mobile-device { width:100%; max-width:390px; height:100vh; max-height:844px; background:var(--bg-base); display:flex; flex-direction:column; align-items:center; justify-content:center; border:1px solid #1A212D; padding:40px 28px; }
        @@media (min-width:400px) { .mobile-device { height:844px; border-radius:40px; box-shadow:0 0 50px rgba(0,0,0,0.8),inset 0 0 0 6px #000; } }
        .check-circle { width:72px; height:72px; background:rgba(70,229,166,0.12); border:1px solid rgba(70,229,166,0.35); border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:24px; }
        .check-circle svg { width:32px; height:32px; stroke:var(--accent-green); fill:none; stroke-width:2.5; stroke-linecap:round; stroke-linejoin:round; }
        h2 { font-size:24px; font-weight:700; color:var(--text-main); text-align:center; margin-bottom:10px; }
        p { font-size:14px; color:var(--text-muted); text-align:center; line-height:1.6; margin-bottom:32px; }
        p strong { color:var(--accent-blue); }
        .btn-auth { display:block; width:100%; padding:16px; border-radius:14px; border:none; background:var(--accent-blue); color:#fff; font-weight:700; font-size:16px; cursor:pointer; font-family:'DM Sans',sans-serif; text-align:center; text-decoration:none; }
    </style>
</head>
<body>
    <div class="mobile-device">
        <div class="check-circle">
            <svg viewBox="0 0 24 24"><polyline points="4 12 9 17 20 7" /></svg>
        </div>
        <h2>Check Your Email</h2>
        <p>We've sent a confirmation link to<br /><strong>@email</strong><br />Please click the link to activate your account.</p>
        <p>
            If you don't receive the email within a few minutes, please check your spam folder or
            <a asp-action="ResendEmailConfirmation" asp-route-email="@ViewBag.Email">click here to resend the confirmation email</a>.
        </p>
        <a href="@Url.Action("Login", "User")" class="btn-auth">Back to Sign In</a>
    </div>
</body>
</html>
