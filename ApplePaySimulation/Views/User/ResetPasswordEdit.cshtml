@model ApplePaySimulation.Models.ViewModels.Authentication.ResetPasswordEditViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>XenoPay · New Password</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg-base:#05070A; --bg-surface:#10141D; --text-main:#F1F5F9; --text-muted:#8B9BB4; --text-faint:#4A5568; --accent-blue:#2E7BCF; --border-color:#2A3647; --danger:#FF6B6B; }
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:'DM Sans',sans-serif; background:#000; display:flex; align-items:center; justify-content:center; min-height:100vh; }
        .mobile-device { width:100%; max-width:390px; height:100vh; max-height:844px; background:var(--bg-base); display:flex; flex-direction:column; border:1px solid #1A212D; position:relative; overflow:hidden; }
        @@media (min-width:400px) { .mobile-device { height:844px; border-radius:40px; box-shadow:0 0 50px rgba(0,0,0,0.8),inset 0 0 0 6px #000; } }
        .bg-glow { position:absolute; border-radius:50%; filter:blur(80px); pointer-events:none; z-index:0; }
        .glow-blue { width:260px; height:260px; background:rgba(46,123,207,0.12); top:-60px; left:-60px; }
        .status-bar { padding:14px 24px 0; z-index:10; position:relative; }
        .status-time { font-size:15px; font-weight:600; color:var(--text-main); }
        .auth-content { flex:1; overflow-y:auto; display:flex; flex-direction:column; padding:0 28px 40px; position:relative; z-index:1; }
        .auth-heading { font-size:24px; font-weight:700; color:var(--text-main); margin-bottom:6px; }
        .auth-sub { font-size:14px; color:var(--text-muted); margin-bottom:32px; line-height:1.5; }
        .field { margin-bottom:14px; }
        .field label { display:block; font-size:11px; font-weight:600; color:var(--text-muted); letter-spacing:0.08em; text-transform:uppercase; margin-bottom:7px; }
        .field-wrap { position:relative; }
        .field-wrap input { width:100%; background:var(--bg-surface); border:1px solid var(--border-color); color:var(--text-main); padding:15px 46px 15px 16px; border-radius:14px; font-size:15px; font-family:'DM Sans',sans-serif; outline:none; transition:border-color 0.2s,box-shadow 0.2s; }
        .field-wrap input:focus { border-color:var(--accent-blue); box-shadow:0 0 0 3px rgba(46,123,207,0.12); }
        .field-wrap input.input-validation-error { border-color:var(--danger); }
        .field-icon { position:absolute; right:14px; top:50%; transform:translateY(-50%); color:var(--text-faint); cursor:pointer; display:flex; align-items:center; }
        .field-icon svg { width:18px; height:18px; stroke:currentColor; fill:none; stroke-width:2; }
        .field-validation-error { font-size:12px; color:var(--danger); margin-top:5px; display:block; }
        .validation-summary-errors ul { list-style:none; padding:0; }
        .validation-summary-errors li { font-size:13px; color:var(--danger); margin-bottom:4px; }
        .btn-auth { width:100%; padding:16px; border-radius:14px; border:none; background:var(--accent-blue); color:#fff; font-weight:700; font-size:16px; cursor:pointer; font-family:'DM Sans',sans-serif; transition:opacity 0.2s; margin-top:6px; }
        .btn-auth:hover { opacity:0.88; }
        .back-btn { display:inline-flex; align-items:center; gap:6px; background:none; border:none; cursor:pointer; color:var(--text-muted); font-size:14px; font-family:'DM Sans',sans-serif; padding:0; margin-bottom:24px; text-decoration:none; transition:color 0.15s; }
        .back-btn svg { width:18px; height:18px; stroke:currentColor; fill:none; stroke-width:2.2; }
    </style>
</head>
<body>
    <div class="mobile-device">
        <div class="bg-glow glow-blue"></div>
        <div class="status-bar"><span class="status-time" id="clock">9:41</span></div>
        <div class="auth-content">
            <a class="back-btn" href="@Url.Action("Login", "User")">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>Back
            </a>
            <div style="padding:0 0 28px;">
                <div class="auth-heading">New Password</div>
                <div class="auth-sub">Enter and confirm your new password below.</div>
            </div>

            @using (Html.BeginForm("NewPassword", "User", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input asp-for="userId" type="hidden" />
                <input asp-for="token" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="field">
                    <label asp-for="NewPassword">New Password</label>
                    <div class="field-wrap">
                        <input asp-for="NewPassword" type="password" id="np-pwd" placeholder="Min. 8 characters" />
                        <div class="field-icon" onclick="togglePwd('np-pwd',this)">
                            <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                        </div>
                    </div>
                    <span asp-validation-for="NewPassword" class="field-validation-error"></span>
                </div>

                <div class="field">
                    <label asp-for="ConfirmPassword">Confirm Password</label>
                    <div class="field-wrap">
                        <input asp-for="ConfirmPassword" type="password" id="np-confirm" placeholder="Repeat your password" />
                        <div class="field-icon" onclick="togglePwd('np-confirm',this)">
                            <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                        </div>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn-auth">Update Password</button>
            }
        </div>
    </div>
    <script>
        document.getElementById('clock').textContent = new Date().toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
        function togglePwd(id, el) {
            const inp = document.getElementById(id);
            inp.type = inp.type === 'text' ? 'password' : 'text';
        }
    </script>
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
